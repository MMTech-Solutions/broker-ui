# broker-service base URL (Laravel)
BROKER_SERVICE_URL=http://localhost:8000

# API prefix exposed by broker-service routes/api.php
BROKER_API_PREFIX=/api/broker

# Gateway headers required by mmtech/iam-rbac middleware
RBAC_GATEWAY_INTERNAL_HEADER=X-Internal-Gateway
RBAC_GATEWAY_INTERNAL_SECRET=apisix
RBAC_GATEWAY_USERINFO_HEADER=X-Userinfo

# Dev identity for BFF → broker-service (JSON or pre-encoded Base64URL)
# RBAC_ADMIN_USERINFO_JSON={"sub":"b8f4e2a1-3c6d-4e9f-8b2a-7d1e9f4c6a50","email":"dev.admin@broker-service.local","given_name":"Dev Admin","family_name":"User"}
# RBAC_CUSTOMER_USERINFO_JSON={"sub":"b8f4e2a1-3c6d-4e9f-8b2a-7d1e9f4c6a51","email":"dev.customer@broker-service.local","given_name":"Dev Customer","family_name":"User"}
# Legacy fallback (admin):
# RBAC_USERINFO_JSON={"sub":"b8f4e2a1-3c6d-4e9f-8b2a-7d1e9f4c6a50","email":"dev.admin@broker-service.local","given_name":"Dev Admin","family_name":"User"}
# RBAC_USERINFO_BASE64=eyJzdWIiOiJiOGY0ZTJhMS0zYzZkLTRlOWYtOGIyYS03ZDFlOWY0YzZhNTAiLCJlbWFpbCI6ImRldi5wb3N0bWFuQGJyb2tlci1zZXJ2aWNlLmxvY2FsIiwiZ2l2ZW5fbmFtZSI6IlBvc3RtYW4gUkJBQyBEZXYgVXNlciIsImZhbWlseV9uYW1lIjoiVGVzdGVyIn0

# Reverb (live risk metrics). Leave unset to disable WebSocket client.
# NEXT_PUBLIC_REVERB_APP_KEY=local-reverb-key
# NEXT_PUBLIC_REVERB_HOST=localhost
# NEXT_PUBLIC_REVERB_PORT=8081
# NEXT_PUBLIC_REVERB_SCHEME=http
