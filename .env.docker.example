# Copiar a mmt-broker-basic-ui/.env para desarrollo local fuera de Docker.
# En Docker Compose las variables se inyectan desde docker-compose.yml.

BROKER_SERVICE_URL=http://localhost:8000
BROKER_API_PREFIX=/api/broker

RBAC_GATEWAY_INTERNAL_HEADER=X-Internal-Gateway
RBAC_GATEWAY_INTERNAL_SECRET=apisix
RBAC_GATEWAY_USERINFO_HEADER=X-Userinfo

# Usuarios dev por superficie (admin vs cliente)
RBAC_ADMIN_USERINFO_JSON={"sub":"b8f4e2a1-3c6d-4e9f-8b2a-7d1e9f4c6a50","email":"dev.admin@broker-service.local","given_name":"Dev Admin","family_name":"User"}
RBAC_CUSTOMER_USERINFO_JSON={"sub":"b8f4e2a1-3c6d-4e9f-8b2a-7d1e9f4c6a51","email":"dev.customer@broker-service.local","given_name":"Dev Customer","family_name":"User"}
